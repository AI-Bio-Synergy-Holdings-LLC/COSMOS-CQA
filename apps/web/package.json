{
  "name": "@ai-bio-synergy/cosmos-cqa-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Public portal and browser workbench for COSMOS-CQA research workflows.",
  "engines": {
    "node": ">=24",
    "npm": ">=10"
  },
  "scripts": {
    "check:legacy": "node ./scripts/check-legacy-syntax.mjs",
    "check:portal-deploy": "node ./scripts/check-public-portal-deployment.mjs",
    "check:quality-budgets": "node ./scripts/check-quality-budgets.mjs",
    "check:repo-health": "node ./scripts/check-repo-health.mjs",
    "check:seo-exposure": "node ./scripts/check-seo-exposure.mjs",
    "check:source": "node ./scripts/check-source-syntax.mjs",
    "pages:check-dns": "node ./scripts/check-pages-dns.mjs",
    "pages:prepare": "node ./scripts/prepare-pages-artifact.mjs",
    "test:contracts": "node --test ./test/contracts.test.mjs",
    "test:unit": "node --test ./test/unit/*.test.mjs",
    "test:core-pack": "node --test ./test/core-pack-intake.test.mjs",
    "test:legacy-extraction": "node --test ./test/legacy-script-extraction.test.mjs",
    "test:browser": "playwright test",
    "test:replay": "node --test ./test/replay.test.mjs",
    "validate:core-pack": "node ./scripts/validate-core-pack.mjs examples/core-pack/core-pack.manifest.json",
    "validate:public-data-candidates": "node ./scripts/validate-core-pack.mjs examples/public-data-candidates/legacy-survey-core-pack.manifest.json",
    "check": "npm run check:repo-health && npm run check:portal-deploy && npm run check:seo-exposure && npm run check:quality-budgets && npm run check:source && npm run test:contracts && npm run test:unit && npm run test:core-pack && npm run validate:core-pack && npm run validate:public-data-candidates && npm run test:legacy-extraction && npm run test:replay && npm run test:browser && npm run check:legacy",
    "evidence:checklist": "node ./scripts/generate-checklist-targets.mjs",
    "release:artifacts": "node ./scripts/generate-release-artifacts.mjs",
    "serve": "node ./scripts/serve.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
